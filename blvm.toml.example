# BLVM Node Configuration Example
# Copy this file to blvm.toml and customize as needed
# Usage: blvm --config blvm.toml

# Network listening address
listen_addr = "0.0.0.0:8333"

# Transport: TOML serde uses tcponly | irohonly | quinnonly | hybrid | all (CLI/ENV use tcp_lowercase)
transport_preference = "tcponly"

# Maximum number of peers
max_peers = 100

# Protocol version: "BitcoinV1", "Testnet3", or "Regtest"
protocol_version = "Regtest"

# Enable self-advertisement (send own address to peers)
enable_self_advertisement = true

# Persistent peers (peers to connect to on startup)
# persistent_peers = ["1.2.3.4:8333", "5.6.7.8:8333"]

# Stratum V2 (merge-mining / pool; miner TCP = blvm-stratum-v2 module — requires feature)
# [stratum_v2]
# enabled = false
# pool_url = "tcp://pool.example.com:3333"
# listen_addr = "0.0.0.0:3333"   # informational on node; miner TCP is the module
# p2p_stratum_demux = true
# transport_preference = "tcponly"
# merge_mining_enabled = false
# secondary_chains = []

# RPC authentication configuration
# [rpc_auth]
# required = false
# tokens = []
# certificates = []
# rate_limit_burst = 100
# rate_limit_rate = 10

# Ban list sharing configuration
# [ban_list_sharing]
# enabled = false
# share_interval_seconds = 3600
# max_entries = 1000

# Storage and pruning configuration
# [storage]
# database_backend = "auto"  # default release build: usually RocksDB; or force "redb", "sled", etc.
# 
# [storage.pruning]
# mode = { type = "normal", keep_from_height = 0, min_recent_blocks = 288 }
# auto_prune = true
# min_blocks_to_keep = 144

# Module system configuration
[modules]
enabled = true
modules_dir = "modules"
data_dir = "data/modules"
socket_dir = "data/modules/sockets"
# Discovery index for bootstrap-download of modules listed in enabled_modules but missing on disk.
# Default matches shipped `blvm` / `ModuleConfig::default()`.
registry_url = "https://raw.githubusercontent.com/BTCDecoded/blvm/main/registry/modules.json"
# Official modules: auto-load on disk, or bootstrap from each repo’s GitHub Release (module.toml [downloads]).
# Set to [] to skip bootstrap and only load modules already under modules_dir.
# Optional: add "blvm-marketplace" for loadmodule / registry browsing.
enabled_modules = ["blvm-miniscript", "blvm-zmq"]
# Opt-out: never auto-load or bootstrap-download these names (manifest `name`), even if on disk.
# disabled_modules = ["some-module"]

# Per-module configuration overrides (passed to each module via env on spawn)
[modules.blvm-marketplace]
# modules_dir is inherited from [modules].modules_dir above
# (Legacy: you could set registry_url here instead of under [modules].)

[modules.blvm-zmq]
hashblock = "tcp://127.0.0.1:28332"
hashtx = "tcp://127.0.0.1:28333"
rawblock = "tcp://127.0.0.1:28334"
rawtx = "tcp://127.0.0.1:28335"
sequence = "tcp://127.0.0.1:28336"
